    },
    {
      "item": "PaymentIntent metadata",
      "test": "Check Stripe Dashboard: Payment Intent details",
      "expected": "metadata.sessionId, metadata.plan, metadata.customerEmail populated"
    },
    {
      "item": "Webhook signature verification",
      "test": "Send invalid X-Stripe-Signature header",
      "expected": "n8n returns 400, event not processed"
    },
    {
      "item": "Invoice creation",
      "test": "Check InvoiceNinja: Invoices list",
      "expected": "New invoice created with sessionId reference"
    },
    {
      "item": "Session activation",
      "test": "Check database: session.status = 'active'",
      "expected": "Session marked as active only after invoice created"
    },
    {
      "item": "Portal access",
      "test": "Use sessionId to access portal",
      "expected": "Portal shows customer details and plan info"
    },
    {
      "item": "Error handling & logging",
      "test": "Send malformed payload",
      "expected": "n8n logs error, moves to DLQ, retry scheduled"
    },
    {
      "item": "Idempotence",
      "test": "Send same event twice with 2sec delay",
      "expected": "First creates invoice, second returns 200 but no duplicate"
    },
    {
      "item": "Failed payment flow",
      "test": "Send payment_intent.payment_failed event",
      "expected": "Session marked failed, email sent to customer"
    },
    {
      "item": "InvoiceNinja API connectivity",
      "test": "curl to /api/v1/clients endpoint",
      "expected": "Returns client list with 200 OK"
    }
  ],
