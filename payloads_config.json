  "test_scenarios": [
    {
      "name": "Happy Path - Full Purchase Flow",
      "steps": [
        "1. User clicks 'Buy' on wizard",
        "2. Client sends wizard_webhook payload",
        "3. n8n creates sessionId and PaymentIntent",
        "4. Returns client_secret to client",
        "5. Client opens Stripe payment form",
        "6. Client enters card and completes payment",
        "7. Stripe fires payment_intent.succeeded webhook",
        "8. n8n verifies signature and processes event",
        "9. n8n creates client in InvoiceNinja",
        "10. n8n creates invoice",
        "11. n8n marks session as active",
        "12. Client can now access portal with sessionId"
      ]
    },
    {
      "name": "Failed Payment - Retry Flow",
      "steps": [
        "1-6. Same as above but card is declined",
        "7. Stripe fires payment_intent.payment_failed webhook",
        "8. n8n verifies signature and processes event",
        "9. n8n marks session as failed",
        "10. n8n sends email to client with retry link",
        "11. Client receives email and retries with different card",
        "12. If successful, goes back to Happy Path step 7"
      ]
    },
    {
      "name": "Idempotence - Stripe Retry",
      "steps": [
        "1. Stripe fires payment_intent.succeeded event",
        "2. n8n processes and creates invoice",
        "3. n8n response timeout or network error",
        "4. Stripe automatically retries the webhook (same event ID)",
        "5. n8n receives duplicate event",
        "6. n8n checks if sessionId already processed",
        "7. Returns 200 OK but does NOT create duplicate invoice",
        "8. idempotency_key or sessionId ensures only 1 invoice exists"
      ]
    },
    {
      "name": "Webhook Signature Verification Failure",
      "steps": [
        "1. Attacker sends fake webhook to /webhook/stripe-webhook-legado",
        "2. n8n receives webhook",
        "3. n8n extracts X-Stripe-Signature header",
        "4. n8n verifies against Stripe webhook secret",
        "5. Verification fails (invalid signature)",
        "6. n8n returns 400 Bad Request",
        "7. Event is NOT processed",
        "8. n8n logs security event for audit"
      ]
    }
  ],
  "validation_checklist": [
    {
      "item": "Webhook reachability",
      "test": "curl -I https://vmi2945958.contaboserver.net/webhook/legado-wizard",
      "expected": "HTTP 200 or 405 (method not allowed for OPTIONS is OK)"
    },
    {
