      "parameters": {
        "jsCode": "// STEP 5: Parsear evento de Stripe\nconst body = $input.first().json.body || {};\n\nconst eventType = body.type || '';\nconst dataObj = (body.data && body.data.object) ? body.data.object : {};\nconst chargesArr = (dataObj.charges && dataObj.charges.data && dataObj.charges.data.length > 0) ? dataObj.charges.data[0] : {};\nconst meta = dataObj.metadata || {};\n\nreturn [{\n  json: {\n    eventType: eventType,\n    paymentIntentId: dataObj.id || '',\n    status: dataObj.status || '',\n    amount: dataObj.amount || 0,\n    amountReceived: dataObj.amount_received || 0,\n    currency: dataObj.currency || 'usd',\n    sessionId: meta.sessionId || '',\n    plan: meta.plan || '',\n    paymentType: meta.paymentType || '',\n    customerEmail: meta.customerEmail || '',\n    succeeded: dataObj.status === 'succeeded',\n    created: dataObj.created || 0,\n    chargeId: chargesArr.id || '',\n    chargeStatus: chargesArr.status || '',\n    receiptUrl: chargesArr.receipt_url || ''\n  }\n}];\n"
      },
