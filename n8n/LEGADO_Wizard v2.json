      "parameters": {
        "jsCode": "// STEP 1: Generar Session ID unico\nconst sessionId = 'sess_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);\n\nconst body = $input.first().json.body || {};\n\nconst intent = (body.intent || '').toLowerCase();\nconst plan = body.plan || body.formPayload?.plan || null;\nconst paymentType = body.paymentType || body.formPayload?.paymentType || 'monthly';\nconst buyer = body.buyer || body.formPayload?.buyer || body.formPayload?.titular || {};\nconst family = body.family || body.formPayload?.family || [];\nconst timestamp = body.timestamp || new Date().toISOString();\n\nlet resolvedIntent = 'other';\n\nif (intent === 'confirm') {\n  resolvedIntent = 'confirm';\n} else if (intent === 'payment_success') {\n  resolvedIntent = 'payment_success';\n} else if (intent === 'chat' || intent === 'other') {\n  resolvedIntent = intent;\n}\n\nreturn [{\n  json: {\n    sessionId,\n    intent: resolvedIntent,\n    plan,\n    paymentType,\n    buyer,\n    family,\n    timestamp,\n    email: buyer.email || ''\n  }\n}];\n"
      },
